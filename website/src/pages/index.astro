---
import { Code } from 'astro-expressive-code/components'

// Load code examples from separate .cs files
import heroCode from '../examples/hero.cs?raw'
import heroSource from '../examples/hero-source.cs?raw'
import hoverSource from '../examples/hover.cs?raw'
import xmldocSource from '../examples/xmldoc.cs?raw'
import errorsSource from '../examples/errors.cs?raw'
import noErrorsSource from '../examples/no-errors.cs?raw'
import highlightSource from '../examples/highlight.cs?raw'
import regionSource from '../examples/region.cs?raw'
import cutSource from '../examples/cut.cs?raw'
import pkgSource from '../examples/pkg.cs?raw'

const sources = {
  hover: hoverSource.trimEnd(),
  xmldoc: xmldocSource.trimEnd(),
  errors: errorsSource.trimEnd(),
  noErrors: noErrorsSource.trimEnd(),
  highlight: highlightSource.trimEnd(),
  region: regionSource.trimEnd(),
  cut: cutSource.trimEnd(),
  pkg: pkgSource.trimEnd(),
}
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Glo# — twoslash for C#</title>
		<meta name="description" content="Rich, interactive C# code snippets powered by Roslyn. Hover tooltips, compile verification, and beautiful rendering for your documentation." />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
	</head>
	<body>
		<!-- Nav -->
		<nav>
			<div class="nav-inner">
				<a href="/" class="logo">
					Glo<span class="logo-hash">#</span>
				</a>
				<div class="nav-links">
					<a href="#features">Features</a>
					<a href="#how-it-works">How it works</a>
					<a href="#integrations">Integrations</a>
					<a href="#setup">Get started</a>
					<a href="https://github.com/nicknash/glosharp" class="nav-github" aria-label="GitHub">
						<svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
					</a>
				</div>
			</div>
		</nav>

		<!-- Hero -->
		<section class="hero">
			<div class="container">
				<!-- Glowing Logo -->
				<div class="hero-logo">
					<div class="hero-logo-aurora"></div>
					<div class="hero-logo-aurora hero-logo-aurora--2"></div>
					<div class="hero-logo-aurora hero-logo-aurora--3"></div>
					<div class="hero-logo-text">
						<span class="hero-logo-glo">Glo</span><span class="hero-logo-hash">#</span>
					</div>
				</div>
				<div class="hero-badge">twoslash for C#</div>
				<h1>Rich, interactive C# code snippets<br/>powered by <span class="gradient-text">Roslyn</span></h1>
				<p class="hero-subtitle">
					Add hover tooltips, IntelliSense completions, and compile verification to your C# documentation.
					Zero runtime JavaScript. Built on the same compiler that powers Visual Studio.
				</p>
				<div class="hero-actions">
					<a href="#setup" class="btn btn-primary">Get started</a>
					<a href="#features" class="btn btn-secondary">See features</a>
				</div>
				<div class="hero-code">
					<div class="example-container hero-example">
						<div class="example-tabs">
							<div class="example-tab-pill"></div>
							<button class="example-tab active" data-view="result">Result</button>
							<button class="example-tab" data-view="source">Source</button>
						</div>
						<div class="example-content-wrapper">
							<div class="feature-example example-rendered">
								<Code lang="csharp" code={heroCode} />
							</div>
							<pre class="feature-example example-source"><code>{heroSource}</code></pre>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Value Props -->
		<section class="value-props">
			<div class="container">
				<div class="props-grid">
					<div class="prop">
						<div class="prop-icon">
							<svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
						</div>
						<h3>Compiler-verified</h3>
						<p>Every snippet is compiled by Roslyn. Catch errors in documentation before your readers do.</p>
					</div>
					<div class="prop">
						<div class="prop-icon">
							<svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
						</div>
						<h3>IDE-quality hovers</h3>
						<p>Full type signatures, XML doc comments, parameter info, and overload counts&mdash;just like Visual Studio.</p>
					</div>
					<div class="prop">
						<div class="prop-icon">
							<svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
						</div>
						<h3>Zero runtime JS</h3>
						<p>Tooltips use CSS anchor positioning. No JavaScript shipped to your readers&mdash;ever.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Features -->
		<section id="features" class="features">
			<div class="container">
				<h2 class="section-title">Everything you need for<br/><span class="gradient-text">beautiful C# documentation</span></h2>

				<div class="feature-grid">
					<div class="feature-card">
						<div class="feature-header">
							<span class="feature-icon">^?</span>
							<h3>Hover queries</h3>
						</div>
						<p>Place <code>// ^?</code> markers below any token to show its type signature and documentation inline. Readers see exactly what they'd see in their IDE.</p>
						<div class="example-container">
							<div class="example-tabs">
								<div class="example-tab-pill"></div>
								<button class="example-tab active" data-view="result">Result</button>
								<button class="example-tab" data-view="source">Source</button>
							</div>
							<div class="example-content-wrapper">
								<div class="feature-example example-rendered">
									<Code lang="csharp" code={`// @noErrors\nvar items = new List<int> { 1, 2, 3 };\nvar count = items.Count;\n//  ^?`} />
								</div>
								<pre class="feature-example example-source"><code>{sources.hover}</code></pre>
							</div>
						</div>
					</div>

					<div class="feature-card">
						<div class="feature-header">
							<span class="feature-icon">^?</span>
							<h3>XML documentation</h3>
						</div>
						<p>Full extraction of <code>&lt;summary&gt;</code>, <code>&lt;param&gt;</code>, <code>&lt;returns&gt;</code>, <code>&lt;remarks&gt;</code>, and <code>&lt;exception&gt;</code> tags. Rendered in structured, readable popups.</p>
						<div class="example-container">
							<div class="example-tabs">
								<div class="example-tab-pill"></div>
								<button class="example-tab active" data-view="result">Result</button>
								<button class="example-tab" data-view="source">Source</button>
							</div>
							<div class="example-content-wrapper">
								<div class="feature-example example-rendered">
									<Code lang="csharp" code={`// @noErrors\nvar items = new List<int> { 1, 2, 3 };\n//              ^?\nvar total = items.Sum();`} />
								</div>
								<pre class="feature-example example-source"><code>{sources.xmldoc}</code></pre>
							</div>
						</div>
					</div>

					<div class="feature-card">
						<div class="feature-header">
							<span class="feature-icon">@errors</span>
							<h3>Error assertions</h3>
						</div>
						<p>Expect specific compiler errors with <code>// @errors: CS1002</code>. Verify error messages and severity. Use <code>// @noErrors</code> to assert clean compilation.</p>
						<div class="example-container">
							<div class="example-tabs">
								<div class="example-tab-pill"></div>
								<button class="example-tab active" data-view="result">Result</button>
								<button class="example-tab" data-view="source">Source</button>
							</div>
							<div class="example-content-wrapper">
								<div class="feature-example example-rendered">
									<Code lang="csharp" code={`// @errors: CS0029\nint x = "hello";`} />
								</div>
								<pre class="feature-example example-source"><code>{sources.errors}</code></pre>
							</div>
						</div>
					</div>

					<div class="feature-card">
						<div class="feature-header">
							<span class="feature-icon">@noErrors</span>
							<h3>Compile verification</h3>
						</div>
						<p>Assert your snippets compile cleanly with <code>// @noErrors</code>. Catch documentation bugs in CI before your readers find them.</p>
						<div class="example-container">
							<div class="example-tabs">
								<div class="example-tab-pill"></div>
								<button class="example-tab active" data-view="result">Result</button>
								<button class="example-tab" data-view="source">Source</button>
							</div>
							<div class="example-content-wrapper">
								<div class="feature-example example-rendered">
									<Code lang="csharp" code={`// @noErrors\nvar items = new List<int> { 1, 2, 3 };\nvar sum = items.Sum();\nConsole.WriteLine($"Sum: {sum}");`} />
								</div>
								<pre class="feature-example example-source"><code>{sources.noErrors}</code></pre>
							</div>
						</div>
					</div>

					<div class="feature-card">
						<div class="feature-header">
							<span class="feature-icon">@highlight</span>
							<h3>Visual annotations</h3>
						</div>
						<p>Highlight, focus, and diff lines with <code>// @highlight</code>, <code>// @focus</code>, and <code>// @diff: +/-</code>. Guide your reader's attention to what matters.</p>
						<div class="example-container">
							<div class="example-tabs">
								<div class="example-tab-pill"></div>
								<button class="example-tab active" data-view="result">Result</button>
								<button class="example-tab" data-view="source">Source</button>
							</div>
							<div class="example-content-wrapper">
								<div class="feature-example example-rendered">
									<Code lang="csharp" code={`// @suppressErrors\nvar config = LoadConfig();\nvar conn = config.GetConnection();\n// @highlight\nvar db = new DbContext(conn);`} />
								</div>
								<pre class="feature-example example-source"><code>{sources.highlight}</code></pre>
							</div>
						</div>
					</div>

					<div class="feature-card">
						<div class="feature-header">
							<span class="feature-icon">#region</span>
							<h3>Region extraction</h3>
						</div>
						<p>Extract named <code>#region</code> blocks from full source files. The entire file compiles for accurate types, but only the region appears in output.</p>
						<div class="example-container">
							<div class="example-tabs">
								<div class="example-tab-pill"></div>
								<button class="example-tab active" data-view="result">Result</button>
								<button class="example-tab" data-view="source">Source</button>
							</div>
							<div class="example-content-wrapper">
								<div class="feature-example example-rendered">
									<Code lang="csharp" code={`// @suppressErrors\n// @hide\npublic class User {\n  public string First { get; set; }\n  public string Last { get; set; }\n// @show\n  public string FullName\n    => $"{First} {Last}";\n// @hide\n}`} />
								</div>
								<pre class="feature-example example-source"><code>{sources.region}</code></pre>
							</div>
						</div>
					</div>

					<div class="feature-card">
						<div class="feature-header">
							<span class="feature-icon">---cut---</span>
							<h3>Hidden setup code</h3>
						</div>
						<p>Hide boilerplate with <code>// ---cut---</code> or <code>// @hide</code>/<code>// @show</code>. Setup code compiles but doesn't appear in the rendered snippet.</p>
						<div class="example-container">
							<div class="example-tabs">
								<div class="example-tab-pill"></div>
								<button class="example-tab active" data-view="result">Result</button>
								<button class="example-tab" data-view="source">Source</button>
							</div>
							<div class="example-content-wrapper">
								<div class="feature-example example-rendered">
									<Code lang="csharp" code={`#:sdk Microsoft.NET.Sdk.Web\nvar builder = WebApplication.CreateBuilder(args);\nvar app = builder.Build();\n// ---cut---\napp.MapGet("/", () => "Hello");\napp.Run();`} />
								</div>
								<pre class="feature-example example-source"><code>{sources.cut}</code></pre>
							</div>
						</div>
					</div>

					<div class="feature-card">
						<div class="feature-header">
							<span class="feature-icon">#:pkg</span>
							<h3>File-based apps</h3>
						</div>
						<p>On .NET 10+, use <code>#:package</code> and <code>#:sdk</code> directives directly in your code. No separate <code>.csproj</code> needed&mdash;your snippet is valid C# and Glo# input.</p>
						<div class="example-container">
							<div class="example-tabs">
								<div class="example-tab-pill"></div>
								<button class="example-tab active" data-view="result">Result</button>
								<button class="example-tab" data-view="source">Source</button>
							</div>
							<div class="example-content-wrapper">
								<div class="feature-example example-rendered">
									<Code lang="csharp" code={`#:package Newtonsoft.Json@13.0.3\nusing Newtonsoft.Json;\nvar json = JsonConvert.SerializeObject(new { x = 1 });`} />
								</div>
								<pre class="feature-example example-source"><code>{sources.pkg}</code></pre>
							</div>
						</div>
					</div>

					<div class="feature-card">
						<div class="feature-header">
							<span class="feature-icon fast-icon">&harr;</span>
							<h3>Two-layer caching</h3>
						</div>
						<p>In-process compilation context cache plus SHA256-keyed disk cache. Rebuilds are fast. Atomic writes handle concurrent processes safely.</p>
						<div class="feature-example">
							<Code lang="bash" code={`$ glosharp verify samples/ --cache-dir .glosharp-cache
✓ 24 files verified (18 cached)
  Completed in 1.2s`} />
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- How it works -->
		<section id="how-it-works" class="how-it-works">
			<div class="container">
				<h2 class="section-title">How it works</h2>
				<p class="section-subtitle">Glo# runs at build time. Your readers never download extra JavaScript.</p>

				<div class="steps">
					<div class="step">
						<div class="step-number">1</div>
						<div class="step-content">
							<h3>Write C# with markers</h3>
							<p>Add <code>// ^?</code> markers to show hover info, <code>// @errors</code> to assert compiler errors, and directives like <code>// @highlight</code> to annotate visually.</p>
						</div>
					</div>
					<div class="step">
						<div class="step-number">2</div>
						<div class="step-content">
							<h3>Roslyn compiles &amp; extracts</h3>
							<p>Glo# invokes the Roslyn compiler, resolves symbols, extracts type signatures, XML docs, and diagnostics. Everything is output as structured JSON.</p>
						</div>
					</div>
					<div class="step">
						<div class="step-number">3</div>
						<div class="step-content">
							<h3>Render with your tools</h3>
							<p>Use the Shiki transformer, Expressive Code plugin, or standalone HTML renderer. Hovers become CSS-positioned popups. No JavaScript required.</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Integrations -->
		<section id="integrations" class="integrations">
			<div class="container">
				<h2 class="section-title">Works with your stack</h2>
				<p class="section-subtitle">First-class integrations for the most popular documentation tools.</p>

				<div class="integration-cards">
					<div class="integration-card">
						<h3>Shiki transformer</h3>
						<p class="pkg-name">@glosharp/shiki</p>
						<p>Drop into any Shiki-powered pipeline. Works with Astro, VitePress, and any framework that uses Shiki for syntax highlighting.</p>
						<div class="integration-code">
							<Code lang="js" code={`import { transformerGloSharp } from '@glosharp/shiki'

const html = await codeToHtml(code, {
  lang: 'csharp',
  transformers: [transformerGloSharp({
    project: './My.csproj'
  })]
})`} />
						</div>
					</div>

					<div class="integration-card">
						<h3>Expressive Code plugin</h3>
						<p class="pkg-name">@glosharp/expressive-code</p>
						<p>Full Expressive Code integration with auto-hover extraction. Every C# block gets rich tooltips automatically. Perfect for Starlight docs.</p>
						<div class="integration-code">
							<Code lang="js" code={`import { pluginGloSharp } from '@glosharp/expressive-code'

export default defineConfig({
  integrations: [starlight({
    expressiveCode: {
      plugins: [pluginGloSharp({
        project: './My.csproj'
      })]
    }
  })]
})`} />
						</div>
					</div>

					<div class="integration-card">
						<h3>Standalone HTML</h3>
						<p class="pkg-name">glosharp CLI</p>
						<p>Generate self-contained HTML with no external dependencies. Perfect for Hugo, Jekyll, or any static site. Just embed the output.</p>
						<div class="integration-code">
							<Code lang="bash" code={`$ glosharp render snippet.cs \\
    --theme github-dark \\
    --standalone \\
    --output snippet.html`} />
						</div>
					</div>

					<div class="integration-card">
						<h3>Node.js API</h3>
						<p class="pkg-name">@glosharp/core</p>
						<p>Programmatic access for custom integrations. Full TypeScript types. Build your own rendering pipeline or IDE extension.</p>
						<div class="integration-code">
							<Code lang="js" code={`import { createGloSharp } from '@glosharp/core'

const glosharp = createGloSharp({
  project: './My.csproj'
})
const result = await glosharp.process({
  code: 'var x = 42; // ^?'
})`} />
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Setup -->
		<section id="setup" class="setup">
			<div class="container">
				<h2 class="section-title">Get started in minutes</h2>
				<p class="section-subtitle">Pick the integration that fits your workflow.</p>

				<div class="setup-tabs">
					<div class="tab-buttons">
						<button class="tab-btn active" data-tab="shiki">Astro + Shiki</button>
						<button class="tab-btn" data-tab="ec">Starlight + EC</button>
						<button class="tab-btn" data-tab="cli">CLI</button>
						<button class="tab-btn" data-tab="ci">CI verification</button>
					</div>

					<div class="tab-content active" id="tab-shiki">
						<div class="setup-step">
							<h4>1. Install the .NET tool and npm packages</h4>
							<div class="setup-code">
								<Code lang="bash" code={`dotnet tool install --global GloSharp.Cli
npm install @glosharp/shiki`} />
							</div>
						</div>
						<div class="setup-step">
							<h4>2. Configure your Astro Shiki setup</h4>
							<div class="setup-code">
								<Code lang="js" code={`// astro.config.mjs
import { transformerGloSharp } from '@glosharp/shiki'

export default defineConfig({
  markdown: {
    shikiConfig: {
      transformers: [transformerGloSharp({
        project: './samples/Samples.csproj'
      })]
    }
  }
})`} />
							</div>
						</div>
						<div class="setup-step">
							<h4>3. Write C# code blocks with markers</h4>
							<div class="setup-code">
								<Code lang="md" code={`\`\`\`csharp
var greeting = "Hello, world!";
greeting.Length;
// ^?
\`\`\``} />
							</div>
						</div>
					</div>

					<div class="tab-content" id="tab-ec">
						<div class="setup-step">
							<h4>1. Install the .NET tool and npm packages</h4>
							<div class="setup-code">
								<Code lang="bash" code={`dotnet tool install --global GloSharp.Cli
npm install @glosharp/expressive-code`} />
							</div>
						</div>
						<div class="setup-step">
							<h4>2. Configure the Expressive Code plugin</h4>
							<div class="setup-code">
								<Code lang="js" code={`// astro.config.mjs
import { pluginGloSharp } from '@glosharp/expressive-code'

export default defineConfig({
  integrations: [starlight({
    expressiveCode: {
      plugins: [pluginGloSharp({
        project: './samples/Samples.csproj'
      })]
    }
  })]
})`} />
							</div>
						</div>
						<div class="setup-step">
							<h4>3. Every C# code block is enhanced automatically</h4>
							<p class="setup-note">With auto-hover extraction, all C# blocks get rich tooltips without any markers. Add <code>// ^?</code> for persistent, always-visible hovers.</p>
						</div>
					</div>

					<div class="tab-content" id="tab-cli">
						<div class="setup-step">
							<h4>1. Install the .NET tool</h4>
							<div class="setup-code">
								<Code lang="bash" code="dotnet tool install --global GloSharp.Cli" />
							</div>
						</div>
						<div class="setup-step">
							<h4>2. Process a file</h4>
							<div class="setup-code">
								<Code lang="bash" code={`# Output JSON with type info, hovers, errors
glosharp process snippet.cs --project ./My.csproj

# Generate standalone HTML
glosharp render snippet.cs --theme github-dark --standalone

# Process from stdin
echo 'var x = 42; // ^?' | glosharp process --stdin

# Scaffold a config file
glosharp init`} />
							</div>
						</div>
					</div>

					<div class="tab-content" id="tab-ci">
						<div class="setup-step">
							<h4>1. Add Glo# to your CI pipeline</h4>
							<div class="setup-code">
								<Code lang="bash" code="dotnet tool install --global GloSharp.Cli" />
							</div>
