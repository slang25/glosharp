				color: #c4b5fd;
				font-weight: 500;
			}
			.marker {
				padding: 8px 0;
				font-size: 0.85rem;
				display: flex;
				flex-direction: column;
				gap: 2px;
				border-top: 1px solid rgba(255, 255, 255, 0.04);
			}
			.marker:first-of-type { border-top: none; }
			.marker code {
				font-size: 0.8rem;
				color: #e0e0e8;
			}
			.marker span { color: #666; font-size: 0.8rem; }

			/* CTA */
			.cta {
				padding: 100px 0;
				text-align: center;
			}
			.cta h2 {
				font-size: clamp(1.5rem, 3vw, 2.2rem);
				font-weight: 800;
				margin-bottom: 12px;
			}
			.cta p { color: #888; margin-bottom: 28px; font-size: 1.05rem; }

			/* Footer */
			footer {
				padding: 32px 0;
				border-top: 1px solid rgba(255, 255, 255, 0.04);
				text-align: center;
			}
			footer p { color: #555; font-size: 0.85rem; }

			/* Responsive */
			@media (max-width: 900px) {
				.props-grid { grid-template-columns: 1fr; gap: 24px; }
				.integration-cards { grid-template-columns: 1fr; }
				.markers-grid { grid-template-columns: repeat(2, 1fr); }
			}
			@media (max-width: 640px) {
				.markers-grid { grid-template-columns: 1fr; }
				.nav-links a:not(.nav-github) { display: none; }
				.tab-buttons { flex-wrap: wrap; }
				.tab-btn { flex: unset; }
			}
		</style>

		<style is:global>
			/* EC components render outside Astro's scoped styles */
			.hero-example .expressive-code {
				--ec-codeFontSize: 1.05rem;
			}
			.feature-example .expressive-code,
			.integration-code .expressive-code,
			.setup-code .expressive-code {
				--ec-codeFontSize: 0.9rem;
				margin: 0 !important;
			}
		</style>

		<script>
			// Example Result/Source tab switching with hover + click (includes hero)
			document.querySelectorAll('.example-container').forEach(container => {
				const tabs = container.querySelector('.example-tabs');
				const rendered = container.querySelector('.example-rendered');
				const source = container.querySelector('.example-source');
				const wrapper = container.querySelector('.example-content-wrapper');
				const tabBtns = container.querySelectorAll('.example-tab');
				if (!tabs || !rendered || !source || !wrapper) return;

				let persistedView = 'result';

				function showView(view) {
					const isSource = view === 'source';
					const oldHeight = wrapper.offsetHeight;
					rendered.style.display = isSource ? 'none' : '';
					source.style.display = isSource ? 'block' : 'none';
					const newHeight = wrapper.scrollHeight;
					wrapper.classList.add('animating');
					wrapper.style.height = oldHeight + 'px';
					wrapper.offsetHeight; // force reflow
					wrapper.style.height = newHeight + 'px';
					tabs.classList.toggle('pill-source', isSource);
				}

				wrapper.addEventListener('transitionend', () => {
					wrapper.style.height = '';
					wrapper.classList.remove('animating');
				});

				tabBtns.forEach(btn => {
					// Click to persist — toggle to the other view
					btn.addEventListener('click', () => {
						persistedView = persistedView === 'result' ? 'source' : 'result';
						showView(persistedView);
						tabBtns.forEach(t => t.classList.toggle('active', t.dataset.view === persistedView));
					});
				});
				// Hover anywhere on bar: preview the other view
				tabs.addEventListener('mouseenter', () => {
					const other = persistedView === 'result' ? 'source' : 'result';
					showView(other);
				});
				// Restore persisted view when mouse leaves the tab bar
				tabs.addEventListener('mouseleave', () => {
					showView(persistedView);
				});
			});

			// Setup tab switching
			document.querySelectorAll('.tab-btn').forEach(btn => {
				btn.addEventListener('click', () => {
					const tab = btn.dataset.tab;
					document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
					document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
					btn.classList.add('active');
					document.getElementById(`tab-${tab}`)?.classList.add('active');
				});
			});
		</script>
	</body>
</html>
